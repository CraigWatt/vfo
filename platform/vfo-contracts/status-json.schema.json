{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://craigwatt.github.io/vfo/contracts/status-json.schema.json",
  "title": "vfo status-json schema",
  "type": "object",
  "required": ["schema_version", "healthy", "components", "summary"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "minimum": 1
    },
    "healthy": {
      "type": "boolean"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "state", "detail"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "enum": ["pending", "in_progress", "complete", "error", "skipped"]
          },
          "detail": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["pending", "in_progress", "complete", "error", "skipped"],
      "properties": {
        "pending": {
          "type": "integer",
          "minimum": 0
        },
        "in_progress": {
          "type": "integer",
          "minimum": 0
        },
        "complete": {
          "type": "integer",
          "minimum": 0
        },
        "error": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
